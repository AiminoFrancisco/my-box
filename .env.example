# =====================================================================
# My Borrow Box — Variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# =====================================================================

# ---- Supabase ----
# Las encontrás en: Supabase Dashboard > Project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Llave PÚBLICA (segura para el navegador). Soporta los dos formatos:
#  - Nuevo:  sb_publishable_xxx   -> NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#  - Viejo:  anon JWT             -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# Poné el que tengas (con uno alcanza).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Llave SECRETA (¡solo server! salta RLS). Soporta los dos formatos:
#  - Nuevo:  sb_secret_xxx        -> SUPABASE_SECRET_KEY
#  - Viejo:  service_role JWT     -> SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_SERVICE_ROLE_KEY=

# Connection string de la base (para correr migraciones por CLI/psql).
# Project Settings > Database > Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.TU-PROYECTO.supabase.co:5432/postgres

# ---- Resend (mails transaccionales) ----
# Si se deja vacío, en dev los mails se loguean en consola en vez de enviarse.
RESEND_API_KEY=
RESEND_FROM=My Borrow Box <onboarding@resend.dev>

# ---- App ----
# Email del administrador (recibe avisos / usado en seed)
ADMIN_EMAIL=admin@myborrowbox.com
# Contraseña del admin que crea el seed (cámbiala en producción)
ADMIN_PASSWORD=Admin1234!
# URL pública del sitio (para links en los mails y en el QR)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secreto opcional para proteger el endpoint de cron /api/cargos/recalcular
CRON_SECRET=
